# =============================================================================
# ORA Navigator - Environment Variables Template
# =============================================================================
# Copy this to .env and fill in your actual values
# NEVER commit .env with real credentials!
#
# For Cloud Run: secrets are stored in Secret Manager (see deploy-cloudrun.sh)
# =============================================================================

# --- Vertex AI Agent (ADK) ---
USE_VERTEX_AGENT=true
ADK_APP_NAME=ora_navigator_unified

# For local development:
ADK_BASE_URL=http://127.0.0.1:8081

# For Cloud Run (auto-set during deployment):
# ADK_BASE_URL=https://oranavigator-adk-ollhkgeova-uc.a.run.app

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT=<your-gcp-project-id>

# --- Database (Cloud SQL MySQL) ---
# Local dev: TCP+SSL to public IP. Cloud Run: unix socket via Cloud SQL Auth Proxy.
DATABASE_URL=

# --- Authentication ---
JWT_SECRET=<generate-64-char-random-string>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=240

# --- Admin Account ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=<strong-password>

# --- App URL (used in verification emails, password reset links) ---
APP_URL=https://ora.inavigator.ai

# --- OpenAI (TTS voice feature only; optional) ---
OPENAI_API_KEY=

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3001,http://localhost:5173,http://127.0.0.1:3001,http://127.0.0.1:5173
